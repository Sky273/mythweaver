# --- Local development database (docker-compose.yml) ---
# Only used to run a local Postgres for `npm run dev`. Not used in
# production — Vercel deployments use the Neon connection string injected
# by the Vercel Postgres integration instead (see DATABASE_URL below).
POSTGRES_USER=mythweaver
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mythweaver

# Local dev: points at the docker-compose `db` service via its published
# host port (5434, see docker-compose.yml). In production on Vercel, this
# is instead the pooled Neon connection string, set automatically when you
# add the Postgres (Neon) integration from the Vercel dashboard's Storage tab.
DATABASE_URL=postgresql://mythweaver:changeme@localhost:5434/mythweaver?schema=public

# Vercel Blob read/write token, used for portraits, faction crests, maps,
# documents and character sheet uploads. Created automatically when you add
# a Blob store from the Vercel dashboard's Storage tab; copy it here for
# local dev (`vercel env pull` does this for you — see README).
BLOB_READ_WRITE_TOKEN=

# Secret used to sign auth session tokens. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# LLM provider used for campaign/session content generation: "anthropic" or "openai"
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Campaign maps/documents are always generated with OpenAI's image API,
# regardless of LLM_PROVIDER (Anthropic has no image generation). Requires
# OPENAI_API_KEY above.
OPENAI_IMAGE_MODEL=gpt-image-1

# Max LLM generations (campaign creation, session prep, recap analysis,
# campaign images) per user per calendar month.
MONTHLY_GENERATION_LIMIT=50
